FROM {{ base_image }}

# --- Switch to non-root -----------------------------------------------------
USER agent
WORKDIR /workspace

# Cursor installs to ~/.local/bin
ENV PATH="/tmp/agent_home/.local/bin:${PATH}"
ENV XDG_CONFIG_HOME="$HOME/.config"
ENV XDG_DATA_HOME="$HOME/.local/share"

# --- Install Cursor CLI -----------------------------------------------------
RUN curl https://cursor.com/install -fsS | bash && \
    mkdir -p "$HOME/.cursor" && \
    "$HOME/.local/bin/cursor-agent" --version

# --- Default shell ----------------------------------------------------------
CMD ["cursor-agent"]
