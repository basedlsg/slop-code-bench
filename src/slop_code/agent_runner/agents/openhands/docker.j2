FROM {{ base_image }}

USER root

# Create OpenHands directories outside the workspace mount.
RUN mkdir -p /openhands /opt/openhands-venv && \
    chown -R 1000:1000 /openhands /opt/openhands-venv

# Install tmux (needed by OpenHands)
RUN apt-get update && apt-get install -y tmux && rm -rf /var/lib/apt/lists/*

# Create venv and install OpenHands.
RUN uv venv /opt/openhands-venv --python 3.13 && \
    uv pip install --python /opt/openhands-venv/bin/python --prerelease=allow openhands-ai=={{ version }} \
        ipykernel jupyterlab notebook jupyter \
        jupyter-console jupyter-client nbconvert

USER agent
WORKDIR /workspace
